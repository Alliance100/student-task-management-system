{
  "version": 2,
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node"
    },
    {
      "src": "client/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "api/index.js"
    },
    {
      "src": "/login",
      "dest": "client/login.html"
    },
    {
      "src": "/register",
      "dest": "client/register.html"
    },
    {
      "src": "/(.*)",
      "dest": "client/$1"
    }
  ]
}
